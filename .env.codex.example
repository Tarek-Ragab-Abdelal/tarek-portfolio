# Copy to .env.codex or export these in your shell before running Codex bootstrap tasks.

# Official GitHub MCP bearer token env var name used by Codex.
GITHUB_PAT_TOKEN=

# GitHub Projects MCP stdio server token.
GITHUB_TOKEN=

# Optional if you want to bootstrap the Google Docs MCP server from this repo config.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
